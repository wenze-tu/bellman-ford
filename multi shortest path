import tkinter
from tkinter import ttk

class BellmanFord:
    def __init__(self,edges,node_name,source_node):
        self.edges=edges
        self.pre={}
        self.dis={}
        self.node_name=node_name
        self.source=source_node
        for node in self.node_name:
            self.dis[node]=float('inf')
            self.pre[node]=[]
        self.dis[self.source]=0
        for edge in self.edges:
            if edge.src_node==self.source:
                self.pre[edge.dst_node].append(self.source)
                self.dis[edge.dst_node]=edge.weight
        self.next()
        
        
    def next(self):
        boolean=self.relax()
        if boolean==False:
            self.routes={}
            print('\n')
            for i in range(len(self.node_name)):
                node=self.node_name[i]
                self.routes[node]=[]
                self.route(self.pre,node,node)
            self.get_route(self.pre,self.dis,string='Shortest')
        else:
            return
        
    def relax(self):
        has_negative_circule=False
        for i in range(len(self.node_name)-1):
            for edge in self.edges:
                length1=self.dis[edge.src_node]+edge.weight
                if self.dis[edge.src_node]!=float('inf') and (self.dis[edge.dst_node]==length1) and (edge.src_node not in self.pre[edge.dst_node]) :
                    self.dis[edge.dst_node]=length1
                    self.pre[edge.dst_node].append(edge.src_node)
                if self.dis[edge.src_node]!=float('inf') and (self.dis[edge.dst_node]>length1) :
                    self.dis[edge.dst_node]=length1
                    self.pre[edge.dst_node]=[edge.src_node]
        for edge in self.edges:
            length=self.dis[edge.src_node]+edge.weight
            if self.dis[edge.dst_node]>length: 
                print('\nOrigin: %s->%s dis:%d'%(self.source,edge.dst_node,self.dis[edge.dst_node]))
                print('New: %s->%s->%s dis:%d'%(self.source,edge.src_node,edge.dst_node,float(length)))
                has_negative_circule=True
        return has_negative_circule
        
    
    def route(self,pre,pre_node,dst_node):
        if pre_node==dst_node:
            if pre[dst_node]==[]:
                return
        if len(pre[pre_node])!=0:
            for i in pre[pre_node]:
                self.routes[dst_node].append((i,pre_node))
                self.route(pre,i,dst_node)
    
    def get_route(self,pre,dis,string):
        for node in self.node_name:
            if self.routes[node]==[]:
                print('  %s Distance =%.3f'%(node,dis[node]))
            else:
                 for edge in self.routes[node]:
                    if self.source==edge[0]:
                        print('  %s Route %s -> %s'%(string,edge[0],edge[1]),end='')
                        self.get_next_nodes(edge[1],self.routes[node])
                 print(' Distance =%.3f'%(dis[node]))
                 
    def get_next_nodes(self,node,edges):
        for edge in edges:
            if node==edge[0]:
                print('-> %s'%(edge[1]),end='')
                self.get_next_nodes(edge[1], edges)

